{
  "openapi": "3.1.0",
  "info": {
    "title": "API Framelab",
    "description": "Cette documentation décrit l’API de la société Framelab. Elle présente les différents endpoints disponibles, les méthodes d’authentification, ainsi que les ressources permettant d’interagir avec les services de Framelab.",
    "contact": {
      "email": "julesrisselin@gmail.com"
    },
    "version": "1.0"
  },
  "tags": [
    {
      "name": "Authentification",
      "description": "Pour l'authentification"
    },
    {
      "name": "Users",
      "description": "Accès au utilisateurs"
    },
    {
      "name": "Challenge",
      "description": "Gestion des challenges"
    },
    {
      "name": "Participations",
      "description": "Gestion des Participations"
    },
    {
      "name": "Commentaires",
      "description": "Gestion des Commentaires"
    },
    {
      "name": "Votes",
      "description": "Gestion des Votes"
    }
  ],
  "paths": {
    "/auth/login": {
      "post": {
        "tags": [
          "Authentification"
        ],
        "summary": "Authentification d'un user.",
        "description": "Connexion avec email et mot de passe.",
        "operationId": null,
        "requestBody": {
          "description": "email et mot de passe",
          "content": {
            "application/json": {
              "example": {
                "email": "test@test.gmail",
                "password": "test"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful operation",
            "content": {
              "application/json": {
                "example": {
                  "message": "Votre token a bien été créer",
                  "token": "sidts-CjIBBj1CYpmPBGLqYoEImlLENg_RSepO8-bDLk-Sg69REzRV-_1iKLGb854fX8DjygRKBxAA"
                }
              }
            }
          },
          "401": {
            "description": "Email ou mot de passe incorrect"
          }
        }
      }
    },
    "/auth/logout": {
      "get": {
        "tags": [
          "Authentification"
        ],
        "summary": "Déconnexion d'un user.",
        "description": "Supprimer le token actif d'un user.",
        "requestBody": {
          "description": "Ajout des credentials",
          "content": {
            "application/json": {
              "example": {
                "credentials": "include"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful operation",
            "content": {
              "application/json": {
                "example": {
                  "message": "Le token a bien été supprimé"
                }
              }
            }
          }
        }
      }
    },
    "/users/me": {
      "get": {
        "tags": [
          "Users"
        ],
        "summary": "Renvoi du User connecté.",
        "description": "Retrouver les informations du User connecté.",
        "requestBody": {
          "description": "Ajout des credentials",
          "content": {
            "application/json": {
              "example": {
                "credentials": "include"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful operation",
            "content": {
              "application/json": {
                "example": {
                  "user": {
                    "id": "9,",
                    "email": "test@test.fr",
                    "name": "test",
                    "firstname": null,
                    "date_inscription": "2026-04-09 12:32:53",
                    "is_admin": 0
                  }
                }
              }
            }
          }
        }
      }
    },
    "/users": {
      "post": {
        "tags": [
          "Users"
        ],
        "summary": "Création de compte.",
        "description": "Requête afin de créer son compte",
        "requestBody": {
          "description": "email et mot de passe",
          "content": {
            "application/json": {
              "example": {
                "email": "test@test.gmail",
                "password": "test",
                "name": "test",
                "firstname": "test"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "successful operation",
            "content": {
              "application/json": {
                "example": {
                  "message": "Votre compte a bien été créer"
                }
              }
            }
          }
        }
      },
      "get": {
        "tags": [
          "Users"
        ],
        "summary": "Renvoi du User avec l'id.",
        "description": "Retrouver un User avec son Id.",
        "parameters": [
          {
            "name": "user_id",
            "in": "query",
            "required": true,
            "description": "Par l'id d'un user",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful operation",
            "content": {
              "application/json": {
                "example": {
                  "success": true,
                  "message": {
                    "id": "9,",
                    "email": "test@test.fr",
                    "name": "test",
                    "firstname": null,
                    "date_inscription": "2026-04-09 12:32:53",
                    "is_admin": 0
                  }
                }
              }
            }
          },
          "400": {
            "decription": "Operation failed",
            "content": {
              "application/json": {
                "example": {
                  "success": false,
                  "message": "User don't exist"
                }
              }
            }
          }
        }
      },
      "put": {
        "tags": [
          "Users"
        ],
        "summary": "Activer le compte d'un utilisateurs",
        "description": "Activer le compte lors de la création d'un compte",
        "requestBody": {
          "description": "Un token valable une heure",
          "content": {
            "application/json": {
              "example": {
                "token": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6NTMsImlhdCI6MTc3NDUyMTgxMX0.JOMuvN2Ab6rdk1Lrovqo2Dlf4FU9VsR0Jxr7ZH3-Yuo"
              }
            }
          }
        },
        "required": true,
        "responses": {
          "200": {
            "description": "successful operation",
            "content": {
              "application/json": {
                "example": {
                  "message": "Compte bien activé"
                }
              }
            }
          },
          "401": {
            "description": "operation failed",
            "content": {
              "application/json": {
                "example": {
                  "message": "Token manquant, invalide ou expiré"
                }
              }
            }
          }
        }
      }
    },
    "/challenges": {
      "post": {
        "tags": [
          "Challenge"
        ],
        "summary": "Ajout d'un challenge.",
        "description": "Pour ajouter un challenge.",
        "requestBody": {
          "description": "Informations du Challenge",
          "content": {
            "application/json": {
              "example": {
                "uploaded_file": "test.png",
                "title": "Challenge test",
                "description": "Ceci est un challenge test pour mon API.",
                "date_start": "19/02/2026",
                "date_end": "26/02/2026"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "successful operation",
            "content": {
              "application/json": {
                "example": {
                  "message": "Votre challenge a bien été ajouté"
                }
              }
            }
          },
          "400": {
            "description": "Mauvais format pour l'upload "
          }
        }
      }
    },
    "/challenge/current": {
      "get": {
        "tags": [
          "Challenge"
        ],
        "summary": "Renvoi du challenge en cours",
        "description": "Renvoi du challenge en cours actuellement",
        "responses": {
          "200": {
            "description": "successful operation",
            "content": {
              "application/json": {
                "example": {
                  "id": 9,
                  "title_theme": "Challenge test",
                  "description_theme": "Ceci est un challenge test pour mon API",
                  "picture": "test.png",
                  "date_start": "19/02/2026",
                  "date_end": "26/02/2026"
                }
              }
            }
          },
          "400": {
            "description": "Il n'y pas de challenge en ce moment"
          }
        }
      }
    },
    "/participations": {
      "post": {
        "tags": [
          "Participations"
        ],
        "summary": "Ajouter une participations.",
        "description": "Ajouter une participations si le User est connecté.",
        "requestBody": {
          "description": "Informations de la participation",
          "content": {
            "application/json": {
              "example": {
                "uploaded_file_participations": "test.png",
                "user_id": 1,
                "date_submission": "19/02/2026"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "successful operation",
            "content": {
              "application/json": {
                "example": {
                  "message": "Participation bien ajoutée"
                }
              }
            }
          },
          "400": {
            "description": "Operation failed"
          }
        }
      }
    },
    "/participation": {
      "get": {
        "tags": [
          "Participations"
        ],
        "summary": "Récupérer la/les participations",
        "description": "Sans paramètres renvoie toutes les participations <br> - Avec id_challenge renvoie toutes les participations d'un Challenge <br> - Avec user_id renvoie toutes les participations d'un User <br> - Avec date_submission renvoie toutes les participations d'une date précise <br> - Avec id_participation renvoie la praticipation associée a l'id",
        "parameters": [
          {
            "name": "id_challenge",
            "in": "query",
            "required": false,
            "description": "Par l'id d'un challenge",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "user_id",
            "in": "query",
            "required": false,
            "description": "Par l'id d'un user",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "date_submission",
            "in": "query",
            "required": false,
            "description": "Par date de soumission",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "id_participation",
            "in": "query",
            "required": false,
            "description": "Par l'id d'une participation",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "successful operation",
            "content": {
              "application/json": {
                "example": {
                  "message": {
                    "id": 4,
                    "user_id": 7,
                    "id_challenge": 21,
                    "picture_updated_url": "aboie.png",
                    "date_submission": "01/01/2026",
                    "is_active": true
                  }
                }
              }
            }
          },
          "default": {
            "description": null,
            "content": {
              "application/json": {
                "example": {
                  "message": "{ data [{  id: 9 user_id : 3 id_challenge: 19 picture_updated_url : test.png date_submission: 19/02/2026 is_active : true } { id: 19 user_id : 2 id_challenge: 11 picture_updated_url : fleurs.png date_submission: 11/01/2026 is_active : false } } id: 3 user_id : 16 id_challenge: 9 picture_updated_url : entertaiment.png date_submission: 02/02/2026 is_active : false }] }"
                }
              }
            }
          }
        }
      }
    },
    "/comments": {
      "post": {
        "tags": [
          "Commentaires"
        ],
        "summary": "Envoi de commentaires",
        "description": "Mettre un commentaires sur une publication",
        "requestBody": {
          "description": "Un id de participations, d'un user et un contenu",
          "content": {
            "application/json": {
              "example": {
                "id_participation": 9,
                "user_id": 1,
                "content": "Belle photo"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "successful operation",
            "content": {
              "application/json": {
                "example": {
                  "message": "Votre commentaire a bien été ajouté"
                }
              }
            }
          }
        }
      },
      "put": {
        "tags": [
          "Commentaires"
        ],
        "summary": "Désafficher un commentaire",
        "description": "Supprimer l'affchage d'un commentaires",
        "requestBody": {
          "description": "Un id de commentaires",
          "content": {
            "application/json": {
              "example": {
                "id": 9,
                "is_visible": "0;"
              }
            }
          }
        },
        "required": true,
        "responses": {
          "200": {
            "description": "successful operation",
            "content": {
              "application/json": {
                "example": {
                  "message": "Le commentaire est bien plus affiché. "
                }
              }
            }
          }
        }
      },
      "get": {
        "tags": [
          "Commentaires"
        ],
        "summary": "Récupérer les commentaires par participations",
        "description": "Récupérer les commentaires pour une participations",
        "parameters": [
          {
            "name": "id_participation",
            "in": "query",
            "required": true,
            "description": "Par l'id d'une participation",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "successful operation",
            "content": {
              "application/json": {
                "example": {
                  "message": " { id_participations: 2, user_id: 9, content: 3, date_comment: 2026-03-02 19:04:08, is_visible: 1, }"
                }
              }
            }
          },
          "400": {
            "description": "Not Found",
            "content": {
              "application/json": {
                "example": {
                  "message": "Comment not found"
                }
              }
            }
          }
        }
      }
    },
    "/votes": {
      "get": {
        "tags": [
          "Votes"
        ],
        "summary": "Récupérer les votes par participations",
        "description": "Récupérer les votes pour une participations",
        "parameters": [
          {
            "name": "id_participation",
            "in": "query",
            "required": true,
            "description": "Par l'id d'une participation",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "successful operation",
            "content": {
              "application/json": {
                "example": {
                  "message": " { id_participations: 2, user_id: 9, note_creativity: .3, note_on_theme: 2, note_technique: 1, }"
                }
              }
            }
          },
          "400": {
            "description": "Invalid input",
            "content": {
              "application/json": {
                "example": {
                  "message": "Votes non trouvé"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Votes"
        ],
        "summary": "Envoi de votes",
        "description": "Mettre un vote sur une publication",
        "requestBody": {
          "description": "Un id de participations, d'un user et les 3 notes",
          "content": {
            "application/json": {
              "example": {
                "id_participation": 9,
                "user_id": 1,
                "note_creativity": "3,",
                "note_on_theme": "2,",
                "note_technique": "1,"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "successful operation",
            "content": {
              "application/json": {
                "example": {
                  "message": "Votes bien ajouté."
                }
              }
            }
          }
        }
      }
    }
  }
}